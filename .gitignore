__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Build artifacts
build/work/
build/dist/
dist/
*.spec.bak

# Vendored binaries fetched by setup (large, downloaded, not source)
music_theory/resources/soundfonts/*.sf2
music_theory/resources/soundfonts/*.sf3
music_theory/resources/fluidsynth/

# Local user data should never be committed
*.db
*.sqlite3
settings.json

# Build/test caches (keep the build *scripts* and version resource,
# ignore generated output)
build/*
!build/*.py
!build/version_info.txt
.pytest_cache/

# Installer output (built by the release workflow)
installer/Output/
